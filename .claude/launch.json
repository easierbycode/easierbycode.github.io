{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "vite-dev-server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--port", "5173"],
      "port": 5173
    },
    {
      "name": "gulp-dev-server",
      "runtimeExecutable": "npx",
